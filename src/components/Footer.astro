---
import { SITE_TITLE } from '../consts';

const today = new Date();
---

<footer>
	<div class="links">
		<a href="https://github.com/ryuki-imachi" target="_blank" rel="noopener">GitHub</a>
		<a href="https://qiita.com/ryu-ki" target="_blank" rel="noopener">Qiita</a>
		<a href="/rss.xml">RSS</a>
	</div>
	<p class="copyright">&copy; {today.getFullYear()} {SITE_TITLE}</p>
</footer>
<style>
	footer {
		border-top: 1px solid var(--line);
		padding: 2em 1em 3em;
		color: var(--muted);
		text-align: center;
		font-size: 0.85em;
	}
	.links {
		display: flex;
		justify-content: center;
		gap: 1.6em;
		font-family: var(--font-mono);
	}
	.links a {
		color: var(--muted);
	}
	.links a:hover {
		color: var(--accent);
	}
	.copyright {
		margin: 0.8em 0 0;
		font-family: var(--font-mono);
	}
</style>
