---
// 一覧ページのページ送りUI（issue #19）。paginate()のpageオブジェクトと
// コレクションのベースパス（例: "/tech"）を受け取り、前後シェブロン+全ページ番号を表示する。
// Qiita/Zenn風: 枠線なしのフラットな数字並び、現在ページだけ円形にアクセント色で塗る
// （2026-07-11リュウキ指定）。1ページに収まっている場合は何も表示しない
const { page, basePath } = Astro.props;

const pageUrl = (n: number) => (n === 1 ? `${basePath}/` : `${basePath}/${n}/`);

// ページ数が多いときはQiitaと同様に省略記号で間引く。
// 9ページまでは全表示、10ページ以上は「1 … c-2 c-1 c c+1 c+2 … last」の形。
// 省略が1ページぶんしか隠さない場合は「…」ではなく数字で埋める
function pageItems(current: number, last: number): (number | '…')[] {
	if (last <= 9) return Array.from({ length: last }, (_, i) => i + 1);
	const shown = [...new Set([1, last, current - 2, current - 1, current, current + 1, current + 2])]
		.filter((n) => n >= 1 && n <= last)
		.sort((a, b) => a - b);
	const items: (number | '…')[] = [];
	let prev = 0;
	for (const n of shown) {
		if (n - prev === 2) items.push(prev + 1);
		else if (n - prev > 2) items.push('…');
		items.push(n);
		prev = n;
	}
	return items;
}

const items = pageItems(page.currentPage, page.lastPage);
---

{
	page.lastPage > 1 && (
		<nav class="pagination" aria-label="ページ送り">
			{page.url.prev && (
				<a class="cell nav" href={page.url.prev} aria-label="前のページ">
					‹
				</a>
			)}
			{items.map((n) =>
				n === '…' ? (
					<span class="cell ellipsis" aria-hidden="true">
						…
					</span>
				) : n === page.currentPage ? (
					<span class="cell current" aria-current="page">
						{n}
					</span>
				) : (
					<a class="cell" href={pageUrl(n)}>
						{n}
					</a>
				),
			)}
			{page.url.next && (
				<a class="cell nav" href={page.url.next} aria-label="次のページ">
					›
				</a>
			)}
		</nav>
	)
}

<style>
	.pagination {
		display: flex;
		justify-content: center;
		align-items: center;
		flex-wrap: wrap;
		gap: 0.35em;
		margin-top: 2.2em;
		font-family: var(--font-mono);
		font-size: 1em;
	}
	.cell {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 2.5em;
		height: 2.5em;
		border-radius: 50%;
		color: var(--ink);
		text-decoration: none;
	}
	a.cell:hover {
		background: var(--accent-soft);
		color: var(--accent);
		text-decoration: none;
	}
	.current {
		background: var(--accent);
		color: var(--bg);
		font-weight: 700;
	}
	.nav {
		color: var(--muted);
		font-size: 1.4em;
		padding-bottom: 0.15em; /* ‹›の光学的な上ズレ補正 */
	}
	.ellipsis {
		color: var(--muted);
	}
</style>
