---
import FormattedDate from './FormattedDate.astro';

// tech / travel / others いずれのコレクションの記事も受け取れる一覧コンポーネント。
// ログ行風（日付 + セクションバッジ + タイトル）の表示。リンク先は post.collection から組み立てる。
// showSection: false でバッジを消せる（セクション別一覧ページ用）
const { posts, showSection = true } = Astro.props;
---

<ul class="post-list">
	{
		posts.map((post: any) => (
			<li>
				<a href={`/${post.collection}/${post.id}/`}>
					<span class="date">
						<FormattedDate date={post.data.pubDate} />
					</span>
					{showSection && <span class={`section section-${post.collection}`}>{post.collection}</span>}
					<span class="title">{post.data.title}</span>
				</a>
			</li>
		))
	}
</ul>

<style>
	.post-list {
		list-style-type: none;
		margin: 0;
		padding: 0;
	}
	.post-list li {
		border-bottom: 1px solid var(--line);
	}
	.post-list a {
		display: flex;
		align-items: baseline;
		gap: 0.9em;
		padding: 0.75em 0.4em;
		color: inherit;
		text-decoration: none;
		border-radius: 6px;
	}
	.post-list a:hover {
		background: var(--accent-soft);
		text-decoration: none;
	}
	.post-list a:hover .title {
		color: var(--accent);
	}
	.date {
		font-family: var(--font-mono);
		font-size: 0.82em;
		color: var(--muted);
		flex-shrink: 0;
	}
	.section {
		font-family: var(--font-mono);
		font-size: 0.72em;
		flex-shrink: 0;
		padding: 0.05em 0.5em;
		border: 1px solid currentColor;
		border-radius: 999px;
		line-height: 1.6;
	}
	.section-tech {
		color: var(--c-tech);
	}
	.section-travel {
		color: var(--c-travel);
	}
	.section-others {
		color: var(--c-others);
	}
	.title {
		color: var(--ink-strong);
		line-height: 1.5;
	}
	@media (max-width: 600px) {
		.post-list a {
			flex-wrap: wrap;
			gap: 0.4em 0.9em;
			padding: 0.8em 0.4em;
		}
		.title {
			width: 100%;
		}
	}
</style>
