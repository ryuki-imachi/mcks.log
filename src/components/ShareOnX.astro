---
// 記事をXでシェアするボタン（issue #2）。Web Intentへの静的リンクだけで実現していて、
// APIキーもJavaScriptも不要。開いた投稿画面では文面を自由に編集できるので、
// 自分の記事の告知に使うときは冒頭の一文と一言コメントを手で足す運用。
// 記事ヘッダーのタグ行（BlogPost.astroの.tags）の右端に置かれる前提で、
// margin-left:auto で行末に寄せている。
interface Props {
	title: string;
}

const { title } = Astro.props;
// BaseHeadのcanonical URLと同じ組み立て方
const url = new URL(Astro.url.pathname, Astro.site);
const text = `${title}\n${url}\n\n#mckslog`;
const intentUrl = `https://x.com/intent/post?text=${encodeURIComponent(text)}`;
---

<a class="share-x" href={intentUrl} target="_blank" rel="noopener noreferrer">
	<svg viewBox="0 0 24 24" width="11" height="11" fill="currentColor" aria-hidden="true">
		<path
			d="M18.901 1.153h3.68l-8.04 9.19L24 22.846h-7.406l-5.8-7.584-6.638 7.584H.474l8.6-9.83L0 1.154h7.594l5.243 6.932ZM17.61 20.644h2.039L6.486 3.24H4.298Z"
		/>
	</svg>
	シェア
</a>

<style>
	.share-x {
		margin-left: auto;
		display: inline-flex;
		align-items: center;
		gap: 0.45em;
		font-family: var(--font-mono);
		font-size: 0.98em;
		color: var(--muted);
		border: 1px solid currentColor;
		border-radius: 999px;
		padding: 0.15em 0.8em;
		text-decoration: none;
	}
	.share-x:hover {
		color: var(--accent);
	}
</style>
