---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import type { ImageMetadata, MarkdownHeading } from 'astro';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import ShareOnX from '../components/ShareOnX.astro';
import TableOfContents from '../components/TableOfContents.astro';

type Props = (
	| CollectionEntry<'tech'>['data']
	| CollectionEntry<'memo'>['data']
	| CollectionEntry<'travel'>['data']
	| CollectionEntry<'stream'>['data']
) & {
	// 呼び出し側([...slug].astro)が post.collection を渡すとセクションバッジを表示する
	collection?: string;
	// 記事のid（自動生成OG画像のURL組み立てに使う）
	postId?: string;
	// render(post) が返す見出し一覧。渡すと広い画面でサイド目次を表示する
	headings?: MarkdownHeading[];
};

const {
	title,
	description,
	pubDate,
	updatedDate,
	heroImage,
	tags,
	collection,
	postId,
	headings = [],
} = Astro.props;
// heroImageがあればそれを優先し、なければビルド時に自動生成した記事別OG画像を使う
const ogImage =
	(heroImage as ImageMetadata | undefined) ??
	(collection && postId ? `/og/${collection}/${postId}.png` : undefined);
// 目次に載せるのはh2/h3まで（h4以下は細かすぎるので省く）
const tocHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3);
const hasToc = tocHeadings.length > 0;
---

<html lang="ja">
	<head>
		<BaseHead title={title} description={description} image={ogImage} />
		<style>
			.post-header {
				margin-bottom: 2em;
				padding-bottom: 1.5em;
				border-bottom: 1px solid var(--line);
			}
			.meta {
				display: flex;
				align-items: baseline;
				gap: 0.9em;
				font-family: var(--font-mono);
				font-size: 0.82em;
				color: var(--muted);
			}
			.section {
				font-size: 0.88em;
				padding: 0.05em 0.5em;
				border: 1px solid currentColor;
				border-radius: 999px;
				text-decoration: none;
			}
			.section-tech {
				color: var(--c-tech);
			}
			.section-memo {
				color: var(--c-memo);
			}
			.section-travel {
				color: var(--c-travel);
			}
			.section-stream {
				color: var(--c-stream);
			}
			.post-header h1 {
				font-size: 1.55em;
				margin: 0.4em 0 0.5em;
			}
			.tags {
				display: flex;
				flex-wrap: wrap;
				gap: 0.6em;
				font-family: var(--font-mono);
				font-size: 0.8em;
				color: var(--muted);
			}
			.hero-image {
				margin: 1.5em 0 0;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 8px;
			}
			/* サイド目次は十分に広い画面のときだけ表示する。
			   本文720px + 余白52px + 目次260px の2カラムグリッドに切り替える。
			   本文カラムの左端をヘッダー（720px中央寄せ）と揃えるため、グリッド全体を
			   margin:autoで中央寄せするのではなく、通常時のmainと同じ左端位置
			   (50% - 360px) に固定している。ブレークポイントは、その位置から
			   目次+余白ぶん右にはみ出さない最小幅 720+2*(260+52)=1344px に
			   安全マージンを足した値 */
			.toc-aside {
				display: none;
			}
			@media (min-width: 1360px) {
				main.has-toc {
					width: 1032px;
					margin-left: calc((100% - 720px) / 2);
					margin-right: auto;
					display: grid;
					grid-template-columns: 720px 260px;
					gap: 52px;
					align-items: start;
				}
				/* グリッド子要素のmin-widthはautoが既定値で、幅広のコードブロックが
				   カラム幅を突き破るのを防ぐために明示的に0にする */
				main.has-toc article {
					min-width: 0;
				}
				.toc-aside {
					display: block;
					position: sticky;
					top: 2.5em;
					max-height: calc(100vh - 5em);
					overflow-y: auto;
				}
			}
		</style>
		<style is:global>
			.mermaid-diagram {
				display: flex;
				justify-content: center;
				margin: 1.6em 0;
			}
			.mermaid-diagram svg {
				max-width: 100%;
				height: auto;
			}
		</style>
	</head>

	<body>
		<Header />
		<main class:list={{ 'has-toc': hasToc }}>
			<article>
				<div class="post-header">
					<div class="meta">
						{collection && <a class={`section section-${collection}`} href={`/${collection}/`}>{collection}</a>}
						<FormattedDate date={pubDate} />
						{
							updatedDate && (
								<span class="last-updated-on">
									(更新: <FormattedDate date={updatedDate} />)
								</span>
							)
						}
					</div>
					<h1>{title}</h1>
					{tags && tags.length > 0 && (
						<div class="tags">
							{tags.map((tag: string) => (
								<span>#{tag}</span>
							))}
						</div>
					)}
					{
						heroImage && (
							<div class="hero-image">
								<Image width={720} height={360} src={heroImage} alt="" />
							</div>
						)
					}
				</div>
				<div class="prose">
					<slot />
				</div>
				<ShareOnX title={title} />
			</article>
			{
				hasToc && (
					<aside class="toc-aside">
						<TableOfContents headings={tocHeadings} />
					</aside>
				)
			}
		</main>
		<Footer />
		<script>
			// ```mermaid ブロックをブラウザ側でSVGに描画する。
			// mermaid本体（重い）は図があるページでだけ遅延読み込みされる
			const blocks = document.querySelectorAll('pre[data-language="mermaid"]');
			if (blocks.length > 0) {
				const { default: mermaid } = await import('mermaid');
				const dark = window.matchMedia('(prefers-color-scheme: dark)').matches;
				mermaid.initialize({ startOnLoad: false, theme: dark ? 'dark' : 'neutral' });
				let i = 0;
				for (const pre of blocks) {
					const code = pre.textContent ?? '';
					const container = document.createElement('div');
					container.className = 'mermaid-diagram';
					pre.replaceWith(container);
					try {
						const { svg } = await mermaid.render(`mermaid-diagram-${i++}`, code);
						container.innerHTML = svg;
					} catch {
						// 描画に失敗したら元のコードブロックに戻す（記法ミス時の保険）
						container.replaceWith(pre);
					}
				}
			}
		</script>
	</body>
</html>
