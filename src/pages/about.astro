---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={`About | ${SITE_TITLE}`} description="mcks.log について。このサイトと書いている人のこと" />
	</head>
	<body>
		<Header />
		<main>
			<h1 class="page-title">about/</h1>

			<h2>このサイト</h2>
			<p>
				mcks.log は ryu-ki の個人ブログです。デザインは日々改善していきたいと思っています。
			</p>
			<p>
				記事は4つの置き場に分かれています。
			</p>
			<ul>
				<li><a href="/tech/">tech/</a> — AWSと生成AIを中心にした技術の学び。Qiitaで書いてきた記事も、少しずつここへ引っ越します</li>
				<li><a href="/travel/">travel/</a> — 国内旅行と、JAWS-UG各支部巡りの記録</li>
				<li><a href="/others/">others/</a> — 分類しない雑記。考えごとの垂れ流し</li>
				<li><a href="/memo/">memo/</a> — 技術メモと調査の走り書き。記事にするほどでもない小ネタ</li>
			</ul>

			<h2>書いている人</h2>
			<p>
				ryu-ki（リュウキ）。クラウドとLLMアプリケーションの開発を学びながら、JAWS-UGのイベントにちょくちょく出没しています。
			</p>

			<h2>このサイトの作り</h2>
			<p>
				Astro 7 で書いて Cloudflare Workers で配信しています。ソースコードは
				<a href="https://github.com/ryuki-imachi/mcks.log" target="_blank" rel="noopener">GitHub</a>
				で公開しているので、同じようなブログを作りたい人は参考にどうぞ。更新は
				<a href="/rss.xml">RSS</a> で購読できます。
			</p>
		</main>
		<Footer />
	</body>
</html>

<style>
	.page-title {
		font-family: var(--font-mono);
		font-size: 1.4em;
		margin: 0 0 1em;
		color: var(--accent);
	}
	h2 {
		font-size: 1.15em;
		margin-top: 1.8em;
	}
	ul {
		padding-left: 1.4em;
	}
	li {
		margin-bottom: 0.4em;
	}
</style>
