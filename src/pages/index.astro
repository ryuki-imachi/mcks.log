---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import PostList from '../components/PostList.astro';
import SearchBox from '../components/SearchBox.astro';
import { SECTION_DESCRIPTIONS, SECTIONS, SITE_DESCRIPTION, SITE_TITLE } from '../consts';

// 全コレクションを横断して新着順に並べる
const [tech, memo, travel, stream] = await Promise.all([
	getCollection('tech'),
	getCollection('memo'),
	getCollection('travel'),
	getCollection('stream'),
]);
const published = {
	tech: tech.filter((post) => !post.data.draft),
	memo: memo.filter((post) => !post.data.draft),
	travel: travel.filter((post) => !post.data.draft),
	stream: stream.filter((post) => !post.data.draft),
};
const posts = [...published.tech, ...published.memo, ...published.travel, ...published.stream]
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 10);
const sectionKeys = Object.keys(SECTIONS) as Array<keyof typeof SECTIONS>;
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="intro">
				<p>
					{SITE_DESCRIPTION}
				</p>
			</section>
			<section>
				<h2 class="log-heading">$ ls -l mcks.log</h2>
				<div class="sections">
				{
					sectionKeys.map((key) => (
						<a class={`card card-${key}`} href={`/${key}/`}>
							<span class="card-title">{key}/</span>
							<span class={`card-count${published[key].length === 0 ? ' is-empty' : ''}`}>
								{published[key].length === 0 ? 'empty' : `${published[key].length} posts`}
							</span>
							<span class="card-desc">{SECTION_DESCRIPTIONS[key]}</span>
						</a>
					))
				}
				</div>
			</section>
			<section>
				<h2 class="log-heading">$ tail -f mcks.log</h2>
				<SearchBox />
				<PostList posts={posts} />
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.intro p {
		margin: 0.4em 0 1.8em;
		color: var(--muted);
	}
	.sections {
		display: flex;
		flex-direction: column;
		margin-bottom: 2.8em;
	}
	.card {
		display: flex;
		align-items: baseline;
		gap: 1.1em;
		padding: 0.55em 0.4em;
		border-bottom: 1px solid var(--line);
		text-decoration: none;
		color: inherit;
	}
	.card:hover {
		text-decoration: none;
		background: var(--accent-soft);
	}
	.card-title {
		font-family: var(--font-mono);
		font-weight: 700;
		font-size: 1em;
		width: 5em;
		flex-shrink: 0;
	}
	.card-tech .card-title {
		color: var(--c-tech);
	}
	.card-travel .card-title {
		color: var(--c-travel);
	}
	.card-memo .card-title {
		color: var(--c-memo);
	}
	.card-stream .card-title {
		color: var(--c-stream);
	}
	.card-desc {
		flex: 1;
		font-size: 0.85em;
		line-height: 1.7;
		color: var(--muted);
	}
	.card-count {
		font-family: var(--font-mono);
		font-size: 0.78em;
		color: var(--muted);
		width: 6.5em;
		text-align: right;
		font-variant-numeric: tabular-nums;
		flex-shrink: 0;
	}
	.card-count.is-empty {
		opacity: 0.55;
	}
	@media (max-width: 600px) {
		.card {
			flex-wrap: wrap;
			gap: 0.2em 1em;
		}
		.card-desc {
			width: 100%;
			flex: none;
		}
	}
	.log-heading {
		font-family: var(--font-mono);
		font-size: 1em;
		font-weight: 700;
		color: var(--muted);
		margin: 0 0 0.6em;
	}
</style>
