---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import Pagination from '../../components/Pagination.astro';
import SearchBox from '../../components/SearchBox.astro';
import PostList from '../../components/PostList.astro';
import { SECTION_DESCRIPTIONS, SITE_TITLE } from '../../consts';

// 1ページ20件でページ分けする（/stream/ が1ページ目、/stream/2/ 以降が続き。issue #19）
export async function getStaticPaths({ paginate }: any) {
	const posts = (await getCollection('stream'))
		.filter((post) => !post.data.draft)
		.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
	return paginate(posts, { pageSize: 20 });
}

const { page } = Astro.props;
const pageSuffix = page.currentPage > 1 ? ` (${page.currentPage}/${page.lastPage})` : '';
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={`Stream${pageSuffix} | ${SITE_TITLE}`} description={SECTION_DESCRIPTIONS.stream} />
	</head>
	<body>
		<Header />
		<main>
			<section>
				<div class="page-head">
					<h1 class="page-title" style="color: var(--c-stream)">stream/</h1>
					<a class="rss" href="/stream/rss.xml">RSS</a>
				</div>
				<p class="page-desc">{SECTION_DESCRIPTIONS.stream}</p>
				<SearchBox />
				<PostList posts={page.data} showSection={false} />
				<Pagination page={page} basePath="/stream" />
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.page-head {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
	}
	.page-title {
		font-family: var(--font-mono);
		font-size: 1.4em;
		margin: 0;
	}
	.rss {
		font-family: var(--font-mono);
		font-size: 0.8em;
		color: var(--muted);
	}
	.rss:hover {
		color: var(--accent);
	}
	.page-desc {
		margin: 0.3em 0 1.6em;
		font-size: 0.9em;
		color: var(--muted);
	}
</style>
