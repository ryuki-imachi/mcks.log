---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import PostList from '../../components/PostList.astro';
import { SECTION_DESCRIPTIONS, SITE_TITLE } from '../../consts';

const posts = (await getCollection('stream'))
	.filter((post) => !post.data.draft)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={`Stream | ${SITE_TITLE}`} description={SECTION_DESCRIPTIONS.stream} />
	</head>
	<body>
		<Header />
		<main>
			<section>
				<div class="page-head">
					<h1 class="page-title" style="color: var(--c-stream)">stream/</h1>
					<a class="rss" href="/stream/rss.xml">RSS</a>
				</div>
				<p class="page-desc">{SECTION_DESCRIPTIONS.stream}</p>
				<PostList posts={posts} showSection={false} />
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.page-head {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
	}
	.page-title {
		font-family: var(--font-mono);
		font-size: 1.4em;
		margin: 0;
	}
	.rss {
		font-family: var(--font-mono);
		font-size: 0.8em;
		color: var(--muted);
	}
	.rss:hover {
		color: var(--accent);
	}
	.page-desc {
		margin: 0.3em 0 1.6em;
		font-size: 0.9em;
		color: var(--muted);
	}
</style>
